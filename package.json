{
  "name": "sasonoroso-webserver",
  "version": "1.0.0",
  "description": "Aplikasi Sales Sasonoroso",
  "keywords": [
    "sasonoroso"
  ],
  "homepage": "https://github.com/freezyoff/sasonoroso-webserver#readme",
  "bugs": {
    "url": "https://github.com/freezyoff/sasonoroso-webserver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freezyoff/sasonoroso-webserver.git"
  },
  "license": "ISC",
  "author": "freezyoff",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "SET NODE_ENV=production && node dist/index.js",
    "dev": "SET NODE_ENV=development && nodemon --exec ts-node --esm src/index.ts",
    "dev:db:migrate": "SET NODE_ENV=development && npx sequelize db:migrate --env development",
    "dev:db:undo:all": "SET NODE_ENV=development && npx sequelize db:migrate:undo:all --env development",
    "build": "npx tsc",
    "test": "SET NODE_ENV=test && ts-mocha --",
    "test:all": "SET NODE_ENV=test && ts-mocha --recursive src/tests/**/**.spec.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mysql2": "^3.18.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sequelize-typescript-generator": "^12.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "chai": "^6.2.2",
    "chai-http": "^5.1.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
